              >
                <div
                  className={`w-4 h-4 border flex items-center justify-center transition-colors ${includeNumbers ? "bg-[#4b5320] border-[#c3cc8c] text-[#c3cc8c]" : "bg-[#0e0e0e] border-[#47483c]"}`}
